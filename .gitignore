# ═══════════════════════════════════════════════════
#  MEET — Master .gitignore
# ═══════════════════════════════════════════════════

# --- Environment & Secrets ---
.env
.env.local
.env.*.local
*.env
!.env.example

# --- Node.js ---
node_modules/
dist/
dist-ssr/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/
*.log

# --- Editor & IDE ---
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*~

# --- Vercel ---
.vercel/

# --- Android Build Outputs ---
android/app/build/
android/.gradle/
android/build/
android/local.properties
android/gradle-8.5/
android/gradle-8.5-bin.zip
temp_gradle/
*.hprof

# --- Android Signing ---
*.jks
*.keystore

# --- Python Temp ---
__pycache__/
*.pyc

# --- APK Releases (keep in releases/ only) ---
!releases/*.apk

# --- OS Generated ---
Thumbs.db
ehthumbs.db
Desktop.ini
